{
  "hosting": {
    "public": "dist",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "headers": [
      {
        "source": "**/*.@(js|css|svg|png|jpg|jpeg|gif|ico|woff|woff2)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=31536000, immutable"
          }
        ]
      }
    ],
    "rewrites": [
      {
        "source": "/demo/api/**",
        "run": {
          "serviceId": "prestia-app",
          "region": "us-central1"
        }
      },
      {
        "source": "/demo/health",
        "run": {
          "serviceId": "prestia-app",
          "region": "us-central1"
        }
      },
      {
        "source": "/demo/**",
        "destination": "/demo/index.html"
      },
      {
        "source": "/demo",
        "destination": "/demo/index.html"
      }
    ]
  }
}
