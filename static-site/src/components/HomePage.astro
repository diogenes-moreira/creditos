---
import Layout from '../layouts/Layout.astro';
import LanguageSwitcher from './LanguageSwitcher.astro';
import type { Lang } from '../i18n/translations';
import { t } from '../i18n/utils';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;

const contactId = lang === 'es' ? 'contacto' : lang === 'pt' ? 'contato' : 'contact';
const whatIsId = lang === 'es' ? 'que-es' : lang === 'pt' ? 'o-que-e' : 'what-is';
const featuresId = lang === 'es' ? 'funcionalidades' : lang === 'pt' ? 'funcionalidades' : 'features';
const modulesId = lang === 'es' ? 'modulos' : lang === 'pt' ? 'modulos' : 'modules';
const techId = lang === 'es' ? 'tecnologia' : lang === 'pt' ? 'tecnologia' : 'technology';
---

<Layout title={t(lang, 'meta.title')} description={t(lang, 'meta.description')} lang={lang}>
  <!-- Navigation -->
  <nav class="nav">
    <div class="nav-container">
      <div class="logo"><img src="/images/logo.png" alt="Prestia" class="logo-img" /> Prestia</div>
      <div class="nav-links">
        <a href={`#${whatIsId}`}>{t(lang, 'nav.whatIs')}</a>
        <a href={`#${featuresId}`}>{t(lang, 'nav.features')}</a>
        <a href={`#${modulesId}`}>{t(lang, 'nav.modules')}</a>
        <a href={`#${techId}`}>{t(lang, 'nav.tech')}</a>
        <a href="/docs">{t(lang, 'nav.docs')}</a>
        <LanguageSwitcher lang={lang} />
        <a href={`#${contactId}`} class="btn-nav">{t(lang, 'nav.requestDemo')}</a>
      </div>
      <button class="mobile-menu-btn" aria-label={t(lang, 'nav.menuLabel')}>
        <span></span><span></span><span></span>
      </button>
    </div>
  </nav>

  <!-- Hero -->
  <section class="hero">
    <div class="hero-bg"></div>
    <div class="hero-grid">
      <div class="hero-content">
        <div class="hero-badge">{t(lang, 'hero.badge')}</div>
        <h1>{t(lang, 'hero.title')}</h1>
        <p>{t(lang, 'hero.description')}</p>
        <div class="hero-buttons">
          <a href={`#${contactId}`} class="btn-primary">{t(lang, 'hero.cta')}</a>
          <a href={`#${featuresId}`} class="btn-secondary">{t(lang, 'hero.secondaryCta')}</a>
        </div>
        <div class="hero-stats">
          <div class="stat">
            <span class="stat-value">{t(lang, 'hero.stat1Value')}</span>
            <span class="stat-label">{t(lang, 'hero.stat1Label')}</span>
          </div>
          <div class="stat">
            <span class="stat-value">{t(lang, 'hero.stat2Value')}</span>
            <span class="stat-label">{t(lang, 'hero.stat2Label')}</span>
          </div>
          <div class="stat">
            <span class="stat-value">{t(lang, 'hero.stat3Value')}</span>
            <span class="stat-label">{t(lang, 'hero.stat3Label')}</span>
          </div>
        </div>
      </div>
      <div class="hero-image">
        <img src="/images/hero-person.jpg" alt={t(lang, 'hero.imageAlt')} loading="eager" />
      </div>
    </div>
  </section>

  <div class="wave-divider hero-wave">
    <svg viewBox="0 0 1440 100" preserveAspectRatio="none"><path d="M0,60 C360,100 720,0 1080,60 C1260,90 1380,70 1440,60 L1440,100 L0,100Z" fill="#ffffff"/></svg>
  </div>

  <!-- What is -->
  <section id={whatIsId} class="what-is">
    <div class="section-container">
      <h2>{t(lang, 'whatIs.title')}</h2>
      <div class="what-is-grid">
        <div class="what-is-text">
          <p class="lead" set:html={t(lang, 'whatIs.lead')} />
          <p>{t(lang, 'whatIs.p2')}</p>
          <p>{t(lang, 'whatIs.p3')}</p>
          <ul class="check-list">
            <li set:html={t(lang, 'whatIs.portal1')} />
            <li set:html={t(lang, 'whatIs.portal2')} />
            <li set:html={t(lang, 'whatIs.portal3')} />
          </ul>
        </div>
        <div class="what-is-visual">
          <div class="dashboard-preview">
            <div class="preview-header">
              <div class="preview-dots"><span></span><span></span><span></span></div>
              {t(lang, 'whatIs.dashboardTitle')}
            </div>
            <div class="preview-body">
              <div class="preview-kpi">
                <div class="kpi-card">
                  <span class="kpi-label">{t(lang, 'whatIs.kpi1Label')}</span>
                  <span class="kpi-value">$12.5M</span>
                </div>
                <div class="kpi-card">
                  <span class="kpi-label">{t(lang, 'whatIs.kpi2Label')}</span>
                  <span class="kpi-value">94.2%</span>
                </div>
                <div class="kpi-card">
                  <span class="kpi-label">{t(lang, 'whatIs.kpi3Label')}</span>
                  <span class="kpi-value">847</span>
                </div>
                <div class="kpi-card">
                  <span class="kpi-label">{t(lang, 'whatIs.kpi4Label')}</span>
                  <span class="kpi-value">3.1%</span>
                </div>
              </div>
              <div class="preview-table">
                <div class="table-row header">
                  <span>{t(lang, 'whatIs.tableClient')}</span>
                  <span>{t(lang, 'whatIs.tableAmount')}</span>
                  <span>{t(lang, 'whatIs.tableStatus')}</span>
                </div>
                <div class="table-row">
                  <span>{t(lang, 'whatIs.row1Name')}</span><span>$85.000</span><span class="badge green">{t(lang, 'whatIs.row1Status')}</span>
                </div>
                <div class="table-row">
                  <span>{t(lang, 'whatIs.row2Name')}</span><span>$120.000</span><span class="badge yellow">{t(lang, 'whatIs.row2Status')}</span>
                </div>
                <div class="table-row">
                  <span>{t(lang, 'whatIs.row3Name')}</span><span>$45.000</span><span class="badge blue">{t(lang, 'whatIs.row3Status')}</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Framework -->
  <section class="framework">
    <div class="section-container">
      <h2>{t(lang, 'framework.title')}</h2>
      <div class="framework-content">
        <div class="framework-text">
          <p>{t(lang, 'framework.p1')}</p>
          <p>{t(lang, 'framework.p2')}</p>
        </div>
        <div class="framework-text">
          <p>{t(lang, 'framework.p3')}</p>
          <p class="framework-highlight">{t(lang, 'framework.p4')}</p>
        </div>
      </div>
    </div>
  </section>

  <div class="wave-divider white-to-gray">
    <svg viewBox="0 0 1440 80" preserveAspectRatio="none"><path d="M0,0 C480,80 960,0 1440,60 L1440,80 L0,80Z" fill="#f8f9fa"/></svg>
  </div>

  <!-- Features -->
  <section id={featuresId} class="features">
    <div class="section-container">
      <h2>{t(lang, 'features.title')}</h2>
      <p class="section-subtitle">{t(lang, 'features.subtitle')}</p>
      <div class="feature-grid">
        <div class="feature-card">
          <div class="feature-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#1565C0" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          </div>
          <h3>{t(lang, 'features.clientMgmt.title')}</h3>
          <p>{t(lang, 'features.clientMgmt.desc')}</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#1565C0" stroke-width="2"><rect x="2" y="5" width="20" height="14" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/></svg>
          </div>
          <h3>{t(lang, 'features.creditLines.title')}</h3>
          <p>{t(lang, 'features.creditLines.desc')}</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#1565C0" stroke-width="2"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
          </div>
          <h3>{t(lang, 'features.loans.title')}</h3>
          <p>{t(lang, 'features.loans.desc')}</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#1565C0" stroke-width="2"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
          </div>
          <h3>{t(lang, 'features.dashboard.title')}</h3>
          <p>{t(lang, 'features.dashboard.desc')}</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#1565C0" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
          </div>
          <h3>{t(lang, 'features.payments.title')}</h3>
          <p>{t(lang, 'features.payments.desc')}</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#1565C0" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </div>
          <h3>{t(lang, 'features.audit.title')}</h3>
          <p>{t(lang, 'features.audit.desc')}</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#1565C0" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
          </div>
          <h3>{t(lang, 'features.vendors.title')}</h3>
          <p>{t(lang, 'features.vendors.desc')}</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#1565C0" stroke-width="2"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>
          </div>
          <h3>{t(lang, 'features.accounts.title')}</h3>
          <p>{t(lang, 'features.accounts.desc')}</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#1565C0" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
          </div>
          <h3>{t(lang, 'features.roles.title')}</h3>
          <p>{t(lang, 'features.roles.desc')}</p>
        </div>
      </div>
    </div>
  </section>

  <div class="wave-divider gray-to-white">
    <svg viewBox="0 0 1440 80" preserveAspectRatio="none"><path d="M0,60 C480,0 960,80 1440,20 L1440,80 L0,80Z" fill="#ffffff"/></svg>
  </div>

  <!-- Modules -->
  <section id={modulesId} class="modules">
    <div class="section-container">
      <h2>{t(lang, 'modules.title')}</h2>
      <p class="section-subtitle">{t(lang, 'modules.subtitle')}</p>

      <div class="module-list">
        <div class="module-card">
          <div class="module-img">
            <img src="/images/module-admin.jpg" alt={t(lang, 'modules.admin.imageAlt')} loading="lazy" />
            <div class="module-img-overlay admin"></div>
          </div>
          <div class="module-body">
            <div class="module-header">
              <div class="module-icon admin">A</div>
              <div>
                <h3>{t(lang, 'modules.admin.title')}</h3>
                <span class="module-role">{t(lang, 'modules.admin.role')}</span>
              </div>
            </div>
            <ul>
              <li>{t(lang, 'modules.admin.item1')}</li>
              <li>{t(lang, 'modules.admin.item2')}</li>
              <li>{t(lang, 'modules.admin.item3')}</li>
              <li>{t(lang, 'modules.admin.item4')}</li>
              <li>{t(lang, 'modules.admin.item5')}</li>
              <li>{t(lang, 'modules.admin.item6')}</li>
              <li>{t(lang, 'modules.admin.item7')}</li>
              <li>{t(lang, 'modules.admin.item8')}</li>
              <li>{t(lang, 'modules.admin.item9')}</li>
            </ul>
          </div>
        </div>

        <div class="module-card">
          <div class="module-img">
            <img src="/images/module-vendor.jpg" alt={t(lang, 'modules.client.imageAlt')} loading="lazy" />
            <div class="module-img-overlay client"></div>
          </div>
          <div class="module-body">
            <div class="module-header">
              <div class="module-icon client">C</div>
              <div>
                <h3>{t(lang, 'modules.client.title')}</h3>
                <span class="module-role">{t(lang, 'modules.client.role')}</span>
              </div>
            </div>
            <ul>
              <li>{t(lang, 'modules.client.item1')}</li>
              <li>{t(lang, 'modules.client.item2')}</li>
              <li>{t(lang, 'modules.client.item3')}</li>
              <li>{t(lang, 'modules.client.item4')}</li>
              <li>{t(lang, 'modules.client.item5')}</li>
              <li>{t(lang, 'modules.client.item6')}</li>
            </ul>
          </div>
        </div>

        <div class="module-card">
          <div class="module-img">
            <img src="/images/module-client.jpg" alt={t(lang, 'modules.vendor.imageAlt')} loading="lazy" />
            <div class="module-img-overlay vendor"></div>
          </div>
          <div class="module-body">
            <div class="module-header">
              <div class="module-icon vendor">V</div>
              <div>
                <h3>{t(lang, 'modules.vendor.title')}</h3>
                <span class="module-role">{t(lang, 'modules.vendor.role')}</span>
              </div>
            </div>
            <ul>
              <li>{t(lang, 'modules.vendor.item1')}</li>
              <li>{t(lang, 'modules.vendor.item2')}</li>
              <li>{t(lang, 'modules.vendor.item3')}</li>
              <li>{t(lang, 'modules.vendor.item4')}</li>
              <li>{t(lang, 'modules.vendor.item5')}</li>
              <li>{t(lang, 'modules.vendor.item6')}</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="wave-divider white-to-gray">
    <svg viewBox="0 0 1440 80" preserveAspectRatio="none"><path d="M0,20 C360,80 1080,0 1440,40 L1440,80 L0,80Z" fill="#f8f9fa"/></svg>
  </div>

  <!-- Workflow -->
  <section class="workflow">
    <div class="section-container">
      <h2>{t(lang, 'workflow.title')}</h2>
      <p class="section-subtitle">{t(lang, 'workflow.subtitle')}</p>
      <div class="workflow-steps">
        <div class="workflow-step">
          <div class="step-number">1</div>
          <h3>{t(lang, 'workflow.step1.title')}</h3>
          <p>{t(lang, 'workflow.step1.desc')}</p>
        </div>
        <div class="workflow-arrow"></div>
        <div class="workflow-step">
          <div class="step-number">2</div>
          <h3>{t(lang, 'workflow.step2.title')}</h3>
          <p>{t(lang, 'workflow.step2.desc')}</p>
        </div>
        <div class="workflow-arrow"></div>
        <div class="workflow-step">
          <div class="step-number">3</div>
          <h3>{t(lang, 'workflow.step3.title')}</h3>
          <p>{t(lang, 'workflow.step3.desc')}</p>
        </div>
        <div class="workflow-arrow"></div>
        <div class="workflow-step">
          <div class="step-number">4</div>
          <h3>{t(lang, 'workflow.step4.title')}</h3>
          <p>{t(lang, 'workflow.step4.desc')}</p>
        </div>
      </div>
    </div>
  </section>

  <div class="wave-divider gray-to-white">
    <svg viewBox="0 0 1440 80" preserveAspectRatio="none"><path d="M0,40 C480,80 960,0 1440,60 L1440,80 L0,80Z" fill="#ffffff"/></svg>
  </div>

  <!-- Tech -->
  <section id={techId} class="tech">
    <div class="section-container">
      <h2>{t(lang, 'tech.title')}</h2>
      <p class="section-subtitle">{t(lang, 'tech.subtitle')}</p>
      <div class="tech-grid">
        <div class="tech-item">
          <h4>{t(lang, 'tech.backend.title')}</h4>
          <p>{t(lang, 'tech.backend.desc')}</p>
        </div>
        <div class="tech-item">
          <h4>{t(lang, 'tech.frontend.title')}</h4>
          <p>{t(lang, 'tech.frontend.desc')}</p>
        </div>
        <div class="tech-item">
          <h4>{t(lang, 'tech.db.title')}</h4>
          <p>{t(lang, 'tech.db.desc')}</p>
        </div>
        <div class="tech-item">
          <h4>{t(lang, 'tech.auth.title')}</h4>
          <p>{t(lang, 'tech.auth.desc')}</p>
        </div>
        <div class="tech-item">
          <h4>{t(lang, 'tech.deploy.title')}</h4>
          <p>{t(lang, 'tech.deploy.desc')}</p>
        </div>
        <div class="tech-item">
          <h4>{t(lang, 'tech.audit.title')}</h4>
          <p>{t(lang, 'tech.audit.desc')}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- People Banner -->
  <section class="people-banner">
    <img src="/images/people-team.jpg" alt={t(lang, 'people.imageAlt')} loading="lazy" />
    <div class="people-banner-overlay">
      <div class="people-banner-text">
        <h3>{t(lang, 'people.title')}</h3>
        <p>{t(lang, 'people.desc')}</p>
      </div>
    </div>
  </section>

  <!-- Versions -->
  <section class="versions">
    <div class="section-container">
      <h2>{t(lang, 'versions.title')}</h2>
      <p class="section-subtitle">{t(lang, 'versions.subtitle')}</p>
      <div class="versions-grid">
        <div class="version-card">
          <div class="version-badge opensource-badge">{t(lang, 'versions.opensource.badge')}</div>
          <h3>{t(lang, 'versions.opensource.name')}</h3>
          <p class="version-desc">{t(lang, 'versions.opensource.desc')}</p>
          <ul class="version-features">
            <li>{t(lang, 'versions.opensource.item1')}</li>
            <li>{t(lang, 'versions.opensource.item2')}</li>
            <li>{t(lang, 'versions.opensource.item3')}</li>
            <li>{t(lang, 'versions.opensource.item4')}</li>
            <li>{t(lang, 'versions.opensource.item5')}</li>
            <li>{t(lang, 'versions.opensource.item6')}</li>
            <li>{t(lang, 'versions.opensource.item7')}</li>
            <li>{t(lang, 'versions.opensource.item8')}</li>
          </ul>
          <a href="https://github.com/diogenes-moreira/creditos" class="btn-github" target="_blank" rel="noopener">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
            {t(lang, 'versions.opensource.cta')}
          </a>
        </div>
        <div class="version-card pledg-card">
          <div class="version-badge pledg-badge">{t(lang, 'versions.premium.badge')}</div>
          <h3>{t(lang, 'versions.premium.name')}</h3>
          <p class="version-desc">{t(lang, 'versions.premium.desc')}</p>
          <ul class="version-features">
            <li>{t(lang, 'versions.premium.item1')}</li>
            <li class="highlight">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#E65100" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              {t(lang, 'versions.premium.item2')}
            </li>
            <li class="highlight">
