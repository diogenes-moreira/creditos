---
import HomePage from '../components/HomePage.astro';
---

<HomePage lang="es" />

<script is:inline>
  (function() {
    // Only redirect if user hasn't manually chosen a language before
    if (sessionStorage.getItem('lang_chosen')) return;

    var lang = (navigator.language || navigator.userLanguage || 'es').toLowerCase().split('-')[0];

    if (lang === 'en') {
      sessionStorage.setItem('lang_chosen', 'en');
      window.location.replace('/en/');
    } else if (lang === 'pt') {
      sessionStorage.setItem('lang_chosen', 'pt');
      window.location.replace('/pt/');
    }
    // Spanish or any other language stays on /
  })();
</script>
